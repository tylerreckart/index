[0.083, "o", "\u001b7\u001b[40;1H\r\r\n\u001b[38;5;238m── \u001b[38;5;214mbackend\u001b[38;5;238m (sub) ────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\r\n\u001b[38;5;238m  /mem read\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  /exec zig version\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  [TOOL RESULTS]\u001b[0m\r\r\n\u001b[38;5;238m  No memory file found.\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  [TOOL RESULTS]\u001b[0m\r\r\n\u001b[38;5;238m  0.14.0\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  [TOOL RESULTS]\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  Zig 0.14.0. Writing idiomatic implementation for that version — allocator API and error handling match accordingly.\u001b[0m\r\r\n\u001b[38;5;238m  /write bst.zig\u001b[0m\r\r\n\u001b[38;5;238m  //! Binary Search Tree — Zig 0.14.0\u001b[0m\r\r\n\u001b[38;5;238m  //! Supports: insert, search, delete, in-order/pre-order/post-order traversal.\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  //! Memory: all nodes owned by the tree; deinit frees everything.\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  const std = @import(\"std\");\u001b[0m\r\r\n\u001b[38;5;238m  const Allocator = std.mem.Allocator;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  const Order = std.math.Order;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  // ─── Node ────────────────────────────────────────────────────────────────────\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  pub fn Node(comptime T: type) type {\u001b[0m\r\r\n\u001b[38;5;238m      return struct {\u001b[0m\r\r\n\u001b[38;5;238m          const Self = @This();\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          value: T,\u001b[0m\r\r\n\u001b[38;5;238m          left:  ?*Self = null,\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          right: ?*Self = null,\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          fn init(allocator: Allocator, value: T) Allocator.Error!*Self {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              const node = try allocator.create(Self);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              node.* = .{ .value = value };\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              return node;\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          /// Recursively free this node and all descendants.\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          fn deinit(self: *Self, allocator: Allocator) void {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              if (self.left)  |l| l.deinit(allocator);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              if (self.right) |r| r.deinit(allocator);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              allocator.destroy(self);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      };\u001b[0m\r\r\n\u001b[38;5;238m  }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  // ─── BST ─────────────────────────────────────────────────────────────────────\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  pub fn BST(comptime T: type, comptime compareFn: fn (T, T) Order) type {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      return struct {\u001b[0m\r\r\n\u001b[38;5;238m          const Self = @This();\u001b[0m\r\r\n\u001b[38;5;238m          const NodeT = Node(T);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          allocator: Allocator,\u001b[0m\r\r\n\u001b[38;5;238m          root:      ?*NodeT = null,\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          len:       usize   = 0,\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          pub fn init(allocator: Allocator) Self {\u001b[0m\r\r\n\u001b[38;5;238m              return .{ .allocator = allocator };\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          /// Free all nodes. Tree is unusable after this call.\u001b[0m\r\r\n\u001b[38;5;238m          pub fn deinit(self: *Self) void {\u001b[0m\r\r\n\u001b[38;5;238m              if (self.root) |r| r.deinit(self.allocator);\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              self.root = null;\u001b[0m\r\r\n\u001b[38;5;238m              self.len  = 0;\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          // ── Insert ───────────────────────────────────────────────────────────\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          /// Insert value. Duplicate values are silently ignored.\u001b[0m\r\r\n\u001b[38;5;238m          pub fn insert(self: *Self, value: T) Allocator.Error!void {\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              self.root = try insertNode(self.allocator, self.root, value, &self.len);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          fn insertNode(\u001b[0m\r\r\n\u001b[38;5;238m              allocator: Allocator,\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              maybe_node: ?*NodeT,\u001b[0m\r\r\n\u001b[38;5;238m              value: T,\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              len: *usize,\u001b[0m\r\r\n\u001b[38;5;238m          ) Allocator.Error!?*NodeT {\u001b[0m\r\r\n\u001b[38;5;238m              const node = maybe_node orelse {\u001b[0m\r\r\n\u001b[38;5;238m                  len.* += 1;\u001b[0m\r\r\n\u001b[38;5;238m                  return try NodeT.init(allocator, value);\u001b[0m\r\r\n\u001b[38;5;238m              };\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m              switch (compareFn(value, node.value)) {\u001b[0m\r\r\n\u001b[38;5;238m                  .lt => node.left  = try insertNode(allocator, node.left,  value, len),\u001b[0m\r\r\n\u001b[38;5;238m                  .gt => node.right = try insertNode(allocator, node.right, value, len),\u001b[0m\r\r\n\u001b[38;5;238m                  .eq => {}, // duplicate — no-op\u001b[0m\r\r\n\u001b[38;5;238m              }\u001b[0m\r\r\n\u001b[38;5;238m              return node;\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          // ── Search ───────────────────────────────────────────────────────"]
[0.000, "o", "────\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          /// Returns pointer to the stored value, or null if not found.\u001b[0m\r\r\n\u001b[38;5;238m          pub fn search(self: *const Self, value: T) ?*T {\u001b[0m\r\r\n\u001b[38;5;238m              var current = self.root;\u001b[0m\r\r\n\u001b[38;5;238m              while (current) |node| {\u001b[0m\r\r\n\u001b[38;5;238m                  switch (compareFn(value, node.value)) {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      .lt => current = node.left,\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      .gt => current = node.right,\u001b[0m\r\r\n\u001b[38;5;238m                      .eq => return &node.value,\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                  }\u001b[0m\r\r\n\u001b[38;5;238m              }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              return null;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          pub fn contains(self: *const Self, value: T) bool {\u001b[0m\r\r\n\u001b[38;5;238m              return self.search(value) != null;\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          // ── Delete ───────────────────────────────────────────────────────────\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          /// Remove value from tree. No-op if value absent.\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          pub fn delete(self: *Self, value: T) void {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              self.root = deleteNode(self.allocator, self.root, value, &self.len);\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          fn deleteNode(\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              allocator: Allocator,\u001b[0m\r\r\n\u001b[38;5;238m              maybe_node: ?*NodeT,\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              value: T,\u001b[0m\r\r\n\u001b[38;5;238m              len: *usize,\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          ) ?*NodeT {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              const node = maybe_node orelse return null;\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m              switch (compareFn(value, node.value)) {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                  .lt => {\u001b[0m\r\r\n\u001b[38;5;238m                      node.left = deleteNode(allocator, node.left, value, len);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      return node;\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                  },\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                  .gt => {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                      node.right = deleteNode(allocator, node.right, value, len);\u001b[0m\r\r\n\u001b[38;5;238m                      return node;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                  },\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                  .eq => {\u001b[0m\r\r\n\u001b[38;5;238m                      len.* -= 1;\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m                      // Case 1: no children.\u001b[0m\r\r\n\u001b[38;5;238m                      if (node.left == null and node.right == null) {\u001b[0m\r\r\n\u001b[38;5;238m                          allocator.destroy(node);\u001b[0m\r\r\n\u001b[38;5;238m                          return null;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      // Case 2: one child.\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      if (node.left == null) {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                          const right = node.right;\u001b[0m\r\r\n\u001b[38;5;238m                          allocator.destroy(node);\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                          return right;\u001b[0m\r\r\n\u001b[38;5;238m                      }\u001b[0m\r\r\n\u001b[38;5;238m                      if (node.right == null) {\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                          const left = node.left;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                          allocator.destroy(node);\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                          return left;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      // Case 3: two children — replace with in-order successor\u001b[0m\r\r\n\u001b[38;5;238m                      // (smallest value in right subtree), then delete successor.\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      const successor = findMin(node.right.?);\u001b[0m\r\r\n\u001b[38;5;238m                      node.value = successor.value;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                      // Re-increment len: deleteNode will decrement it again for\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      // the successor removal.\u001b[0m\r\r\n\u001b[38;5;238m                      len.* += 1;\u001b[0m\r\r\n\u001b[38;5;238m                      node.right = deleteNode(allocator, node.right, successor.value, len);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                      return node;\u001b[0m\r\r\n\u001b[38;5;238m                  },\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          fn findMin(node: *NodeT) *NodeT {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              var current = node;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              while (current.left) |l| current = l;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              return current;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          // ── Traversals ───────────────────────────────────────────────────────\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          /// In-order: left → root → right  (sorted ascending for a valid BST).\u001b[0m\r\r\n\u001b[38;5;238m          pub fn inOrder(self: *const Self, context: anytype, comptime visitFn: fn (@TypeOf(context), T) void) void {\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              inOrderNode(self.root, context, visitFn);\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          fn inOrderNode(maybe_node: ?*NodeT, context: anytype, comptime visitFn: fn (@TypeOf(context), T) void) void {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              const node = maybe_node orelse return;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              inOrderNode(node.left,  context, visitFn);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              visitFn(context, node.value);\u001b[0m\r\r\n\u001b[38;5;238m              inOrderNode(node.right, context, visitFn);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          /// Pre-order: root → left → right.\u001b[0m\r\r\n\u001b[38;5;238m          pub fn preOrder(self: *const Self, context: anytype, comptime visitFn: fn (@TypeOf(context), T) void) void {\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              preOrderNode(self.root, context, visitFn);\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          fn preOrderNode(maybe_node: ?*NodeT, context: anytype, comptime visitFn: fn (@TypeOf(context), T) void) void {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              const node = maybe_node orelse return;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              visitFn(context, node.value);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              preOrderNode(node.left,  context, visitFn);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              preOrderNode(node.right, context, visitFn);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          /// Post-order: left → right → root.\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          pub fn postOrder(self: *const Self, context: anytype, comptime visitFn: fn (@TypeOf(context), T) void) void {\u001b[0m\r\r\n\u001b[38;5;238m              postOrderNode(self.root, context, visitFn);\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          fn postOrderNode(maybe_node: ?*NodeT, context: anytype, comptime visitFn: fn (@TypeOf(context), T) void) void {\u001b[0m\r\r\n\u001b[38;5;238m              const node = maybe_node orelse return;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              postOrderNode(node.left,  context, visitFn);\u001b[0m\r\r\n\u001b[38;5;238m              postOrderNode(node.right, context, visitFn);\u001b[0m\r\r\n\u001b[38;5;238m              visitFn(context, node.value);\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          // ── Utility ──────────────────────────────────────────────────────────\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          pub fn height(self: *const Self) usize {\u001b[0m\r\r\n\u001b[38;5;238m              return nodeHeight(self.root);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          fn nodeHeight(maybe_node: ?*NodeT) usize {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              const node = maybe_node orelse return 0;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              const lh = nodeHeight(node.left);\u001b[0m\r\r\n\u001b[38;5;238m              const rh = nodeHeight(node.right);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              return 1 + @max(lh, rh);\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m      };\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  // ─── Comparators ─────────────────────────────────────────────────────────────\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  pub fn compareI32(a: i32, b: i32) Order {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      return std.math.order(a, b);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.001, "o", "\u001b[38;5;238m  pub fn compareU32(a: u32, b: u32) Order {\u001b[0m\r\r\n\u001b[38;5;238m      return std.math.order(a, b);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  // ─── Example usage ───────────────────────────────────────────────────────────\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  pub fn main() !void {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      var gpa = std.heap.GeneralPurposeAllocator(.{}){};\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      defer {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          const status = gpa.deinit();\u001b[0m\r\r\n\u001b[38;5;238m          if (status == .leak) std.debug.print(\"LEAK DETECTED\\n\", .{});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      const allocator = gpa.allocator();\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      const IntBST = BST(i32, compareI32);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      var tree = IntBST.init(allocator);\u001b[0m\r\r\n\u001b[38;5;238m      defer tree.deinit();\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      const stdout = std.io.getStdOut().writer();\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      // ── Insert ───────────────────────────────────────────────────────────────\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      const values = [_]i32{ 50, 30, 70, 20, 40, 60, 80, 10, 25, 35, 45 };\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      for (values) |v| try tree.insert(v);\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      try stdout.print(\"Inserted: {any}\\n\", .{values});\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"Tree size:   {d}\\n\", .{tree.len});\u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"Tree height: {d}\\n\\n\", .{tree.height()});\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      // ── Traversals ───────────────────────────────────────────────────────────\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      try stdout.print(\"In-order (sorted):  \", .{});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      tree.inOrder(stdout, struct {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          fn visit(w: @TypeOf(stdout), v: i32) void {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              w.print(\"{d} \", .{v}) catch {};\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      }.visit);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"\\n\", .{});\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"Pre-order:          \", .{});\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      tree.preOrder(stdout, struct {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          fn visit(w: @TypeOf(stdout), v: i32) void {\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              w.print(\"{d} \", .{v}) catch {};\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      }.visit);\u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"\\n\", .{});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"Post-order:         \", .{});\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      tree.postOrder(stdout, struct {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          fn visit(w: @TypeOf(stdout), v: i32) void {\u001b[0m\r\r\n\u001b[38;5;238m              w.print(\"{d} \", .{v}) catch {};\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m      }.visit);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      try stdout.print(\"\\n\\n\", .{});\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      // ── Search ───────────────────────────────────────────────────────────────\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      const hits   = [_]i32{ 40, 80, 25 };\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      const misses = [_]i32{ 99, -1, 55 };\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      for (hits) |v| {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          try stdout.print(\"search({d:3}): {s}\\n\", .{ v, if (tree.contains(v)) \"FOUND\" else \"NOT FOUND\" });\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      for (misses) |v| {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          try stdout.print(\"search({d:3}): {s}\\n\", .{ v, if (tree.contains(v)) \"FOUND\" else \"NOT FOUND\" });\u001b[0m\r\r\n\u001b[38;5;238m      }\u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"\\n\", .{});\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      // ── Delete ───────────────────────────────────────────────────────────────\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      // Case 1: leaf node.\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"delete(10) [leaf]...\\n\", .{});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      tree.delete(10);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"  size: {d}, contains(10): {}\\n\\n\", .{ tree.len, tree.contains(10) });\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      // Case 2: one child.\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"delete(20) [one child]...\\n\", .{});\u001b[0m\r\r\n\u001b[38;5;238m      tree.delete(20);\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"  size: {d}, contains(20): {}\\n\\n\", .{ tree.len, tree.contains(20) });\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      // Case 3: two children.\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      try stdout.print(\"delete(30) [two children]...\\n\", .{});\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      tree.delete(30);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"  size: {d}, contains(30): {}\\n\\n\", .{ tree.len, tree.contains(30) });\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      // Delete root.\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"delete(50) [root, two children]...\\n\", .{});\u001b[0m\r\r\n\u001b[38;5;238m      tree.delete(50);\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"  size: {d}, contains(50): {}\\n\\n\", .{ tree.len, tree.contains(50) });\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      // Delete absent value — no-op.\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"delete(999) [absent — no-op]...\\n\", .{});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      tree.delete(999);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"  size unchanged: {d}\\n\\n\", .{tree.len});\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      // Final in-order after deletions.\u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"In-order after deletions: \", .{});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      tree.inOrder(stdout, struct {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          fn visit(w: @TypeOf(stdout), v: i32) void {\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              w.print(\"{d} \", .{v}) catch {};\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      }.visit);\u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"\\n\", .{});\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  // ─── Tests ───────────────────────────────────────────────────────────────────\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  test \"insert and search\" {\u001b[0m\r\r\n\u001b[38;5;238m      const allocator = std.testing.allocator;\u001b[0m\r\r\n\u001b[38;5;238m      const IntBST = BST(i32, compareI32);\u001b[0m\r\r\n\u001b[38;5;238m      var tree = IntBST.init(allocator);\u001b[0m\r\r\n\u001b[38;5;238m      defer tree.deinit();\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try tree.insert(5);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try tree.insert(3);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try tree.insert(7);\u001b[0m\r\r\n\u001b[38;5;238m      try tree.insert(1);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      try tree.insert(4);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      try std.testing.expect(tree.contains(5));\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      try std.testing.expect(tree.contains(1));\u001b[0m\r\r\n\u001b[38;5;238m      try std.testing.expect(tree.contains(4));\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try std.testing.expect(!tree.contains(0));\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      try std.testing.expect(!tree.contains(6));\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try std.testing.expectEqual(@as(usize, 5), tree.len);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  test \"duplicate insert ignored\" {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      const allocator = std.testing.allocator;\u001b[0m\r\r\n\u001b[38;5;238m      const IntBST = BST(i32, compareI32);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      var tree = IntBST.init(allocator);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      defer tree.deinit();\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      try tree.insert(10);\u001b[0m\r\r\n\u001b[38;5;238m      try tree.insert(10);\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try tree.insert(10);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      try std.testing.expectEqual(@as(usize, 1), tree.len);\u001b[0m\r\r\n\u001b[38;5;238m  }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  test \"delete leaf\" {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      const allocator = std.testing.allocator;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      const IntBST = BST(i32, compareI32);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      var tree = IntBST.init(allocator);\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      defer tree.deinit();\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try tree.insert(5);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try tree.insert(3);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try tree.insert(7);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      /exec cat bst.zig\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  [TOOL RESULTS]\u001b[0m\r\r\n\u001b[38;5;238m  //! Binary Search Tree — Zig 0.14.0\u001b[0m\r\r\n\u001b[38;5;238m  //! Supports: insert, search, delete, in-order/pre-order/post-order traversal.\u001b[0m\r\r\n\u001b[38;5;238m  //! Memory: all nodes owned by the tree; deinit frees everything.\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  const std = @import(\"std\");\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  const Allocator = std.mem.Allocator;\u001b[0m\r\r\n\u001b[38;5;238m  const Order = std.math.Order;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  // ─── Node ────────────────────────────────────────────────────────────────────\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  pub fn Node(comptime T: type) type {\u001b[0m\r\r\n\u001b[38;5;238m      return struct {\u001b[0m\r\r\n\u001b[38;5;238m          const Self = @This();\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          value: T,\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          left:  ?*Self = null,\u001b[0m\r\r\n\u001b[38;5;238m          right: ?*Self = null,\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          fn init(allocator: Allocator, value: T) Allocator.Error!*Self {\u001b[0m\r\r\n\u001b[38;5;238m              const node = try allocator.create(Self);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              node.* = .{ .value = value };\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              return node;\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          /// Recursively free this node and all descendants.\u001b[0m\r\r\n\u001b[38;5;238m          fn deinit(self: *Self, allocator: Allocator) void {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              if (self.left)  |l| l.deinit(allocator);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              if (self.right) |r| r.deinit(allocator);\u001b[0m\r\r\n\u001b[38;5;238m              allocator.destroy(self);\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      };\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  // ─── BST ─────────────────────────────────────────────────────────────────────\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  pub fn BST(comptime T: type, comptime compareFn: fn (T, T) Order) type {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      return struct {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          const Self = @This();\u001b[0m\r\r\n\u001b[38;5;238m          const NodeT = Node(T);\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          allocator: Allocator,\u001b[0m\r\r\n\u001b[38;5;238m          root:      ?*NodeT = null,\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          len:       usize   = 0,\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          pub fn init(allocator: Allocator) Self {\u001b[0m\r\r\n\u001b[38;5;238m              return .{ .allocator = allocator };\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          /// Free all nodes. Tree is unusable after this call.\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          pub fn deinit(self: *Self) void {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              if (self.root) |r| r.deinit(self.allocator);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              self.root = null;\u001b[0m\r\r\n\u001b[38;5;238m              self.len  = 0;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          // ── Insert ───────────────────────────────────────────────────────────\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          /// Insert value. Duplicate values are silently ignored.\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          pub fn insert(self: *Self, value: T) Allocator.Error!void {\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              self.root = try insertNode(self.allocator, self.root, value, &self.len);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          fn insertNode(\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              allocator: Allocator,\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              maybe_node: ?*NodeT,\u001b[0m\r\r\n\u001b[38;5;238m              value: T,\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              len: *usize,\u001b[0m\r\r\n\u001b[38;5;238m          ) Allocator.Error!?*NodeT {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              const node = maybe_node orelse {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                  len.* += 1;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                  return try NodeT.init(allocator, value);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              };\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              switch (compareFn(value, node.value)) {\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                  .lt => node.left  = try insertNode(allocator, node.left,  value, len),\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                  .gt => node.right = try insertNode(allocator, node.right, value, len),\u001b[0m\r\r\n\u001b[38;5;238m                  .eq => {}, // duplicate — no-op\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              return node;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.001, "o", "\u001b[38;5;238m          // ── Search ───────────────────────────────────────────────────────────\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          /// Returns pointer to the stored value, or null if not found.\u001b[0m\r\r\n\u001b[38;5;238m          pub fn search(self: *const Self, value: T) ?*T {\u001b[0m\r\r\n\u001b[38;5;238m              var current = self.root;\u001b[0m\r\r\n\u001b[38;5;238m              while (current) |node| {\u001b[0m\r\r\n\u001b[38;5;238m                  switch (compareFn(value, node.value)) {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                      .lt => current = node.left,\u001b[0m\r\r\n\u001b[38;5;238m                      .gt => current = node.right,\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      .eq => return &node.value,\u001b[0m\r\r\n\u001b[38;5;238m                  }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              }\u001b[0m\r\r\n\u001b[38;5;238m              return null;\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          pub fn contains(self: *const Self, value: T) bool {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              return self.search(value) != null;\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          // ── Delete ───────────────────────────────────────────────────────────\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          /// Remove value from tree. No-op if value absent.\u001b[0m\r\r\n\u001b[38;5;238m          pub fn delete(self: *Self, value: T) void {\u001b[0m\r\r\n\u001b[38;5;238m              self.root = deleteNode(self.allocator, self.root, value, &self.len);\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          fn deleteNode(\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              allocator: Allocator,\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              maybe_node: ?*NodeT,\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              value: T,\u001b[0m\r\r\n\u001b[38;5;238m              len: *usize,\u001b[0m\r\r\n\u001b[38;5;238m          ) ?*NodeT {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              const node = maybe_node orelse return null;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m              switch (compareFn(value, node.value)) {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                  .lt => {\u001b[0m\r\r\n\u001b[38;5;238m                      node.left = deleteNode(allocator, node.left, value, len);\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      return node;\u001b[0m\r\r\n\u001b[38;5;238m                  },\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                  .gt => {\u001b[0m\r\r\n\u001b[38;5;238m                      node.right = deleteNode(allocator, node.right, value, len);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                      return node;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                  },\u001b[0m\r\r\n\u001b[38;5;238m                  .eq => {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                      len.* -= 1;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m                      // Case 1: no children.\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      if (node.left == null and node.right == null) {\u001b[0m\r\r\n\u001b[38;5;238m                          allocator.destroy(node);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                          return null;\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      // Case 2: one child.\u001b[0m\r\r\n\u001b[38;5;238m                      if (node.left == null) {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                          const right = node.right;\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                          allocator.destroy(node);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                          return right;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                      }\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      if (node.right == null) {\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                          const left = node.left;\u001b[0m\r\r\n\u001b[38;5;238m                          allocator.destroy(node);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                          return left;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      // Case 3: two children — replace with in-order successor\u001b[0m\r\r\n\u001b[38;5;238m                      // (smallest value in right subtree), then delete successor.\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      const successor = findMin(node.right.?);\u001b[0m\r\r\n\u001b[38;5;238m                      node.value = successor.value;\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      // Re-increment len: deleteNode will decrement it again for\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      // the successor removal.\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                      len.* += 1;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      node.right = deleteNode(allocator, node.right, successor.value, len);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m                      return node;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m                  },\u001b[0m\r\r\n\u001b[38;5;238m              }\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          fn findMin(node: *NodeT) *NodeT {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              var current = node;\u001b[0m\r\r\n\u001b[38;5;238m              while (current.left) |l| current = l;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              return current;\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          // ── Traversals ───────────────────────────────────────────────────────\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          /// In-order: left → root → right  (sorted ascending for a valid BST).\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          pub fn inOrder(self: *const Self, context: anytype, comptime visitFn: fn (@TypeOf(context), T) void) void {\u001b[0m\r\r\n\u001b[38;5;238m              inOrderNode(self.root, context, visitFn);\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          fn inOrderNode(maybe_node: ?*NodeT, context: anytype, comptime visitFn: fn (@TypeOf(context), T) void) void {\u001b[0m\r\r\n\u001b[38;5;238m              const node = maybe_node orelse return;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              inOrderNode(node.left,  context, visitFn);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              visitFn(context, node.value);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              inOrderNode(node.right, context, visitFn);\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          /// Pre-order: root → left → right.\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          pub fn preOrder(self: *const Self, context: anytype, comptime visitFn: fn (@TypeOf(context), T) void) void {\u001b[0m\r\r\n\u001b[38;5;238m              preOrderNode(self.root, context, visitFn);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          fn preOrderNode(maybe_node: ?*NodeT, context: anytype, comptime visitFn: fn (@TypeOf(context), T) void) void {\u001b[0m\r\r\n\u001b[38;5;238m              const node = maybe_node orelse return;\u001b[0m\r\r\n\u001b[38;5;238m              visitFn(context, node.value);\u001b[0m\r\r\n\u001b[38;5;238m              preOrderNode(node.left,  context, visitFn);\u001b[0m\r\r\n\u001b[38;5;238m              preOrderNode(node.right, context, visitFn);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          /// Post-order: left → right → root.\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          pub fn postOrder(self: *const Self, context: anytype, comptime visitFn: fn (@TypeOf(context), T) void) void {\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              postOrderNode(self.root, context, visitFn);\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          fn postOrderNode(maybe_node: ?*NodeT, context: anytype, comptime visitFn: fn (@TypeOf(context), T) void) void {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              const node = maybe_node orelse return;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              postOrderNode(node.left,  context, visitFn);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              postOrderNode(node.right, context, visitFn);\u001b[0m\r\r\n\u001b[38;5;238m              visitFn(context, node.value);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m          // ── Utility ──────────────────────────────────────────────────────────\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          pub fn height(self: *const Self) usize {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              return nodeHeight(self.root);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          fn nodeHeight(maybe_node: ?*NodeT) usize {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              const node = maybe_node orelse return 0;\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              const lh = nodeHeight(node.left);\u001b[0m\r\r\n\u001b[38;5;238m              const rh = nodeHeight(node.right);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m              return 1 + @max(lh, rh);\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      };\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  }\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  // ─── Comparators ─────────────────────────────────────────────────────────────\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  pub fn compareI32(a: i32, b: i32) Order {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      return std.math.order(a, b);\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  pub fn compareU32(a: u32, b: u32) Order {\u001b[0m\r\r\n\u001b[38;5;238m      return std.math.order(a, b);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  // ─── Example usage ───────────────────────────────────────────────────────────\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m  pub fn main() !void {\u001b[0m\r\r\n\u001b[38;5;238m      var gpa = std.heap.GeneralPurposeAllocator(.{}){};\u001b[0m\r\r\n\u001b[38;5;238m      defer {\u001b[0m\r\r\n\u001b[38;5;238m          const status = gpa.deinit();\u001b[0m\r\r\n\u001b[38;5;238m          if (status == .leak) std.debug.print(\"LEAK DETECTED\\n\", .{});\u001b[0m\r\r\n\u001b[38;5;238m      }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      const allocator = gpa.allocator();\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      const IntBST = BST(i32, compareI32);\u001b[0m\r\r\n\u001b[38;5;238m      var tree = IntBST.init(allocator);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      defer tree.deinit();\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      const stdout = std.io.getStdOut().writer();\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      // ── Insert ───────────────────────────────────────────────────────────────\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      const values = [_]i32{ 50, 30, 70, 20, 40, 60, 80, 10, 25, 35, 45 };\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      for (values) |v| try tree.insert(v);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"Inserted: {any}\\n\", .{values});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"Tree size:   {d}\\n\", .{tree.len});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"Tree height: {d}\\n\\n\", .{tree.height()});\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      // ── Traversals ───────────────────────────────────────────────────────────\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"In-order (sorted):  \", .{});\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      tree.inOrder(stdout, struct {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          fn visit(w: @TypeOf(stdout), v: i32) void {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m              w.print(\"{d} \", .{v}) catch {};\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      }.visit);\u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"\\n\", .{});\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"Pre-order:          \", .{});\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      tree.preOrder(stdout, struct {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          fn visit(w: @TypeOf(stdout), v: i32) void {\u001b[0m\r\r\n\u001b[38;5;238m              w.print(\"{d} \", .{v}) catch {};\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m      }.visit);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"\\n\", .{});\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"Post-order:         \", .{});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      tree.postOrder(stdout, struct {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          fn visit(w: @TypeOf(stdout), v: i32) void {\u001b[0m\r\r\n\u001b[38;5;238m              w.print(\"{d} \", .{v}) catch {};\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m      }.visit);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"\\n\\n\", .{});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      // ── Search ───────────────────────────────────────────────────────────────\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      const hits   = [_]i32{ 40, 80, 25 };\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      const misses = [_]i32{ 99, -1, 55 };\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      for (hits) |v| {\u001b[0m\r\r\n\u001b[38;5;238m          try stdout.print(\"search({d:3}): {s}\\n\", .{ v, if (tree.contains(v)) \"FOUND\" else \"NOT FOUND\" });\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      }\u001b[0m\r\r\n\u001b[38;5;238m      for (misses) |v| {\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m          try stdout.print(\"search({d:3}): {s}\\n\", .{ v, if (tree.contains(v)) \"FOUND\" else \"NOT FOUND\" });\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      }\u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"\\n\", .{});\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      // ── Delete ───────────────────────────────────────────────────────────────\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      // Case 1: leaf node.\u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"delete(10) [leaf]...\\n\", .{});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      tree.delete(10);\u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"  size: {d}, contains(10): {}\\n\\n\", .{ tree.len, tree.contains(10) });\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      // Case 2: one child.\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"delete(20) [one child]...\\n\", .{});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      tree.delete(20);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"  size: {d}, contains(20): {}\\n\\n\", .{ tree.len, tree.contains(20) });\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      // Case 3: two children.\u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"delete(30) [two children]...\\n\", .{});\u001b[0m\r\r\n\u001b[38;5;238m      tree.delete(30);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      try stdout.print(\"  size: {d}, contains(30): {}\\n\\n\", .{ tree.len, tree.contains(30) });\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      // Delete root.\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"delete(50) [root, two children]...\\n\", .{});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      tree.delete(50);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"  size: {d}, contains(50): {}\\n\\n\", .{ tree.len, tree.contains(50) });\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      // Delete absent value — no-op.\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      try stdout.print(\"delete(999) [absent — no-op]...\\n\", .{});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      tree.delete(999);\u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"  size unchanged: {d}\\n\\n\", .{tree.len});\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  \u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      // Final in-order after deletions.\u001b[0m\r\r\n\u001b[38;5;238m      try stdout.print(\"In-order after deletions: \", .{});\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      tree.inOrder(stdout, struct {\u001b[0m\r\r\n\u001b[38;5;238m          fn visit(w: @TypeOf(stdout), v: i32) void {\u001b[0m\r\r\n\u001b[38;5;238m              w.print(\"{d} \", .{v}) catch {};\u001b[0m\r\r\n\u001b[38;5;238m          }\u001b[0m\r\r\n\u001b[38;5;238m      }.visit);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try stdout.print(\"\\n\", .{});\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  }\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  // ─── Tests ───────────────────────────────────────────────────────────────────\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m  test \"insert and search\" {\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      const allocator = std.testing.allocator;\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      const IntBST = BST(i32, compareI32);\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m      var tree = IntBST.init(allocator);\u001b[0m\r\r\n\u001b[38;5;238m      defer tree.deinit();\u001b[0m"]
[0.000, "o", "\r\r\n\u001b[38;5;238m  \u001b[0m"]
