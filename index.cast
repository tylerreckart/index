[0.000, "o", "\u001b[38;5;238m      try tree.insert(3);\u001b[0m\r\r\n\u001b[38;5;238m      try tree.insert(7);\u001b[0m"]
[0.000, "o", "\r\r\n"]
[0.001, "o", "\u001b[38;5;238m      try tree.insert(1);\u001b[0m\r\r\n"]
[0.000, "o", "\u001b[38;5;238m      try tree.insert(4);\u001b[0m\r\r\n\u001b[38;5;238m  \u001b[0m\r\r\n\u001b[38;5;238m      try std.testing.expect(tree.contains(5));\u001b[0m"]
